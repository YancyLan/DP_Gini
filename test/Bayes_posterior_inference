def posterior_g_trunc_normal(y_obs, gamma, eps, smooth_upper_bound,
                                 mu, sigma, a, b,
                                 M=10_000, rng=None):
    rng = np.random.default_rng(rng)

    g = float(gamma)
    if g <= 1.0:
        raise ValueError("gamma must be > 1")

    s = (4.0 * g / eps) * smooth_upper_bound
    inv_s2 = 1.0 / (sigma * sigma)

    def logpost(x: float) -> float:
        if x < a or x > b:
            return -np.inf
        u = abs((y_obs - x) / s)
        ll = -np.log1p(u ** g)          # correct likelihood for 1/(1+|u|^gamma)
        lp = -0.5 * (x - mu) ** 2 * inv_s2  # truncated normal prior (const ignored)
        return ll + lp

    # Slice sampling within [a, b]
    w, m, burn, thin = 1.0 * sigma, 100, 1_000, 1
    x = float(np.clip(y_obs, a, b))
    samples = np.empty(M, dtype=float)

    kept = 0
    it = 0
    while kept < M:
        it += 1
        lp_x = logpost(x)
        logy = lp_x - rng.exponential(1.0)

        # initial bracket
        u0 = rng.random()
        L = max(a, x - w * u0)
        R = min(b, L + w)

        # stepping out
        j = int(rng.integers(0, m))
        k = (m - 1) - j
        while j > 0 and L > a and logpost(L) > logy:
            L = max(a, L - w)
            j -= 1
        while k > 0 and R < b and logpost(R) > logy:
            R = min(b, R + w)
            k -= 1

        # shrinkage
        while True:
            x_new = L + (R - L) * rng.random()
            if logpost(x_new) >= logy:
                x = x_new
                break
            if x_new < x:
                L = x_new
            else:
                R = x_new

        if it > burn and ((it - burn) % thin == 0):
            samples[kept] = x
            kept += 1

    return samples

def dp_mean(x, L, U, eps, rng=None):
    x = np.asarray(x, dtype=float)
    x = np.clip(x, L, U)
    m = float(x.mean())
    n = x.size
    scale = (U - L) / (n * eps)
    noise = float(rng.laplace(loc=0.0, scale=scale))
    return m + noise


