def make_loglik_phi_power(y_obs: float, scale: float, gamma: float):
    # phi pdf: f(phi) = C_gamma / (1 + |phi|^gamma), gamma>1
    g = float(gamma)
    if g <= 1.0:
        raise ValueError("gamma must be > 1 for normalization")

    # log C_gamma = log(gamma) - log(2*pi) + log(sin(pi/gamma))
    logC = np.log(g) - np.log(2.0 * np.pi) + np.log(np.sin(np.pi / g))

    # y|theta uses change-of-variables: divide by scale
    c0 = logC - np.log(scale)

    def log_likelihood(theta_vec: np.ndarray) -> np.ndarray:
        u = (y_obs - np.asarray(theta_vec)) / scale
        return c0 - np.log1p(np.abs(u) ** g)  # <-- key fix

    return log_likelihood


def sample_prior_g(N, rng=None):
    rng = rng or np.random.default_rng()
    return rng.uniform(0.0, 1.0, size=N)


def bayes_posterior_SIR_uniform(y_obs, gamma, eps, smooth_upper_bound,
                               N=200_000, M=10_000, rng=None):
    rng = rng or np.random.default_rng()
    g_prop = sample_prior_g(N, rng)

    scale = (4.0 * gamma / eps) * smooth_upper_bound
    log_likelihood = make_loglik_phi_power(y_obs, scale, gamma)

    ll = log_likelihood(g_prop)
    ll -= ll.max()
    w = np.exp(ll)
    p = w / w.sum()

    idx = rng.choice(N, size=M, replace=True, p=p)
    return g_prop[idx]

def posterior_g_normal(y_obs, gamma, eps, smooth_upper_bound, mu, sigma, N=200_000, M=10_000, rng=None):
    rng = np.random.default_rng(rng)
    scale = (4 * gamma / eps) * smooth_upper_bound  # Laplace b

    inv_b = 1.0 / scale
    inv_s2 = 1.0 / (sigma * sigma)

    def logpost(x: float) -> float:
        # log p(y_obs | x) + log p(x), up to additive constants
        return -abs(y_obs - x) * inv_b - 0.5 * (x - mu) * (x - mu) * inv_s2

    # Slice sampling (robust for Laplace likelihood * Normal prior)
    w, m, burn, thin = 1.0 * sigma, 100, 1_000, 1
    x = float(y_obs)  # init
    samples = np.empty(M, dtype=float)
    kept = 0
    it = 0

    while kept < M:
        it += 1
        lp_x = logpost(x)
        logy = lp_x - rng.exponential(1.0)

        # bracket [L, R]
        u = rng.random()
        L = x - w * u
        R = L + w
        j = int(rng.integers(0, m))
        k = (m - 1) - j
        while j > 0 and logpost(L) > logy:
            L -= w
            j -= 1
        while k > 0 and logpost(R) > logy:
            R += w
            k -= 1

        # shrinkage
        while True:
            x_new = L + (R - L) * rng.random()
            if logpost(x_new) >= logy:
                x = x_new
                break
            if x_new < x:
                L = x_new
            else:
                R = x_new

        if it > burn and ((it - burn) % thin == 0):
            samples[kept] = x
            kept += 1

    return samples


